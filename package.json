{
  "name": "pipe-pressure-drop",
  "version": "0.1.0",
  "description": "Calculates pressure drop in a water pipe",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "test":              "mocha --timeout 1500000 'test/**/*.test.js'",
